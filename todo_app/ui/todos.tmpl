<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Todo App</title>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
    crossorigin="anonymous"
  />
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
  />
</head>
<body class="bg-light min-vh-100 d-flex flex-column">

  <!-- ═══════════════════════════════════════════════
       HEADER
  ═══════════════════════════════════════════════ -->
  <header class="bg-primary text-white shadow-sm">
    <div class="container py-3 d-flex align-items-center justify-content-between">
      <div class="d-flex align-items-center gap-2">
        <i class="bi bi-check2-square fs-3"></i>
        <span class="fs-4 fw-semibold mb-0">TodoApp</span>
      </div>
      <span class="badge bg-white text-primary fs-6 fw-semibold px-3 py-2">
        {{ len .Todos }} task{{ if ne (len .Todos) 1 }}s{{ end }}
      </span>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════════
       MAIN CONTENT
  ═══════════════════════════════════════════════ -->
  <main class="flex-grow-1">
    <div class="container py-4">

      <!-- Flash message (optional: set .Flash in template data) -->
      {{ if .Flash }}
      <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>{{ .Flash }}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
      {{ end }}

      <div class="row g-4">

        <!-- ─── LEFT COLUMN : Add new todo ───────────── -->
        <div class="col-12 col-lg-4 order-lg-2">
          <div class="card shadow-sm border-0 sticky-lg-top" style="top: 1.5rem;">
            <div class="card-header bg-white border-bottom fw-semibold py-3">
              <i class="bi bi-plus-circle me-2 text-primary"></i>New Task
            </div>
            <div class="card-body">
              <form action="/todos" method="POST">
               
                <div class="mb-3">
                  <label for="todoTitle" class="form-label fw-medium">Task title</label>
                  <input
                    type="text"
                    id="todoTitle"
                    name="title"
                    class="form-control"
                    placeholder="e.g. Buy groceries"
                    required
                    maxlength="255"
                    autofocus
                  />
                  <div class="form-text">Keep it short and actionable.</div>
                </div>
                <div class="d-grid">
                  <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i>Add Task
                  </button>
                </div>
              </form>
            </div>
          </div>
        </div>

        <!-- ─── RIGHT COLUMN : Todo list ─────────────── -->
        <div class="col-12 col-lg-8 order-lg-1">

          <!-- Empty state -->
          {{ if not .Todos }}
          <div class="card shadow-sm border-0 text-center py-5">
            <div class="card-body">
              <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
              <h5 class="fw-semibold mb-1">No tasks yet</h5>
              <p class="text-muted mb-0">Add your first task using the form.</p>
            </div>
          </div>
          {{ end }}

          <!-- Todo list -->
          {{ if .Todos }}
          <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom fw-semibold py-3">
              <i class="bi bi-list-task me-2 text-primary"></i>Your Tasks
            </div>
            <ul class="list-group list-group-flush">

              {{ range .Todos }}
              <li class="list-group-item px-4 py-3" id="todo-{{ .ID }}">

                <!-- ── VIEW MODE (default) ── -->
                <div class="d-flex align-items-start gap-3 view-mode-{{ .ID }}">

                  <!-- Status icon -->
                  <div class="mt-1 flex-shrink-0">
                    {{ if eq .Status "completed" }}
                      <i class="bi bi-check-circle-fill text-success fs-5"></i>
                    {{ else }}
                      <i class="bi bi-circle text-secondary fs-5"></i>
                    {{ end }}
                  </div>

                  <!-- Title + badge -->
                  <div class="flex-grow-1 min-width-0">
                    <p class="mb-1 fw-medium {{ if eq .Status "completed" }}text-decoration-line-through text-muted{{ end }}">
                      {{ .Title }}
                    </p>
                    {{ if eq .Status "completed" }}
                      <span class="badge text-bg-success">Completed</span>
                    {{ else }}
                      <span class="badge text-bg-warning text-dark">Pending</span>
                    {{ end }}
                  </div>

                  <!-- Action buttons -->
                  <div class="d-flex gap-2 flex-shrink-0">

                    <!-- Toggle status -->
                    <form action="/todos/{{ .ID }}/status" method="POST">
                      {{ if eq .Status "completed" }}
                        <input type="hidden" name="status" value="pending" />
                        <button
                          type="submit"
                          class="btn btn-outline-warning btn-sm"
                          title="Mark as pending"
                          data-bs-toggle="tooltip"
                        >
                          <i class="bi bi-arrow-counterclockwise"></i>
                        </button>
                      {{ else }}
                        <input type="hidden" name="status" value="completed" />
                        <button
                          type="submit"
                          class="btn btn-outline-success btn-sm"
                          title="Mark as completed"
                          data-bs-toggle="tooltip"
                        >
                          <i class="bi bi-check-lg"></i>
                        </button>
                      {{ end }}
                    </form>

                    <!-- Inline edit toggle -->
                    <button
                      type="button"
                      class="btn btn-outline-primary btn-sm"
                      title="Edit"
                      data-bs-toggle="tooltip"
                      onclick="showEditMode('{{ .ID }}')"
                    >
                      <i class="bi bi-pencil"></i>
                    </button>

                    <!-- Delete -->
                    <form
                      action="/todos/{{ .ID }}/delete"
                      method="POST"
                      onsubmit="return confirm('Delete this task?')"
                    >
                      <button
                        type="submit"
                        class="btn btn-outline-danger btn-sm"
                        title="Delete"
                        data-bs-toggle="tooltip"
                      >
                        <i class="bi bi-trash3"></i>
                      </button>
                    </form>

                  </div>
                </div>
                <!-- END VIEW MODE -->

                <!-- ── EDIT MODE (hidden by default) ── -->
                <div class="edit-mode-{{ .ID }} d-none">
                  <form action="/todos/{{ .ID }}/edit" method="POST">
                    <div class="input-group">
                      <input
                        type="text"
                        name="title"
                        class="form-control form-control-sm"
                        value="{{ .Title }}"
                        required
                        maxlength="255"
                      />
                      <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-floppy me-1"></i>Save
                      </button>
                      <button
                        type="button"
                        class="btn btn-outline-secondary btn-sm"
                        onclick="hideEditMode('{{ .ID }}')"
                      >
                        Cancel
                      </button>
                    </div>
                  </form>
                </div>
                <!-- END EDIT MODE -->

              </li>
              {{ end }}

            </ul>
            <!-- Card footer: quick summary -->
            <div class="card-footer bg-white border-top text-muted small py-2 px-4 d-flex justify-content-between">
              <span>
                {{ .CompletedCount }} of {{ len .Todos }} completed
              </span>
              {{ if .Todos }}
              <form action="/todos/completed/delete-all" method="POST" class="d-inline">
                <button
                  type="submit"
                  class="btn btn-link btn-sm p-0 text-danger text-decoration-none"
                  onclick="return confirm('Remove all completed tasks?')"
                >
                  <i class="bi bi-trash3 me-1"></i>Clear completed
                </button>
              </form>
              {{ end }}
            </div>
          </div>
          {{ end }}

        </div>
        <!-- END RIGHT COLUMN -->

      </div>
    </div>
  </main>

  <!-- ═══════════════════════════════════════════════
       FOOTER
  ═══════════════════════════════════════════════ -->
  <footer class="bg-white border-top mt-auto py-3">
    <div class="container text-center text-muted small">
      &copy; {{ .Year }} TodoApp &mdash; Built with Go &amp; Bootstrap 5
    </div>
  </footer>

  <!-- Bootstrap JS bundle -->
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmBrKhqXDiRVnba9Ur+fh2bQGhT"
    crossorigin="anonymous"
  ></script>

  <script>
    // ── Inline edit helpers ────────────────────────────────────────
    function showEditMode(id) {
      document.querySelector('.view-mode-' + id).classList.add('d-none');
      document.querySelector('.edit-mode-' + id).classList.remove('d-none');
      // Focus the input
      document.querySelector('.edit-mode-' + id + ' input[name="title"]').focus();
    }

    function hideEditMode(id) {
      document.querySelector('.edit-mode-' + id).classList.add('d-none');
      document.querySelector('.view-mode-' + id).classList.remove('d-none');
    }

    // ── Bootstrap tooltips ─────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
      const tooltipEls = document.querySelectorAll('[data-bs-toggle="tooltip"]');
      tooltipEls.forEach(function (el) {
        new bootstrap.Tooltip(el, { trigger: 'hover' });
      });
    });
  </script>

</body>
</html>
